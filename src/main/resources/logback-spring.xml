<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ═══════════════════════════════════════════════════
         Patrón de log idéntico al que usaba log4j2.xml:
         fecha  [hilo]  nivel  clase - mensaje
         ═══════════════════════════════════════════════════ -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{1} - %msg%n"/>

    <!--
        Nombre del fichero de log: se toma del System Property que
        HardwareHubApplication.main() fija ANTES de arrancar Spring.
        Funciona igual que ${sys:app.log.file} en log4j2.xml.
    -->
    <property name="LOG_FILE" value="${app.log.file}"/>

    <!-- ── Appender: consola ────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Appender: fichero (un fichero nuevo por arranque, sin append) -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_FILE}</file>
        <append>false</append>
        <immediateFlush>true</immediateFlush>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Root logger: nivel INFO, escribe en consola y fichero ── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>

